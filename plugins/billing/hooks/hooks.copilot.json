{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash \"$COPILOT_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash \"$COPILOT_PLUGIN_ROOT/hooks/scripts/session-end.sh\"",
        "timeoutSec": 15
      }
    ]
  }
}
