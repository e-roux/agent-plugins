{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-session-start.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-pre-tool.sh\"",
            "name": "make-first-guards",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}