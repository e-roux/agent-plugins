{
  "name": "make-first",
  "description": "Make-centric development plugin: enforces Makefile structure, TDD practices, shell scripting standards, and the uv/Python toolchain. Auto-redirects direct tool invocations to make targets.",
  "version": "0.12.9",
  "author": {
    "name": "Emmanuel Roux"
  },
  "license": "MIT",
  "keywords": [
    "makefile",
    "make",
    "development",
    "build",
    "toolchain",
    "python",
    "uv"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/pre-tool.sh\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}