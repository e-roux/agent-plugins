{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmit": [
      {
        "type": "command",
        "bash": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/branch-check-turn.sh\"",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/pre-tool.sh\"",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/post-tool.sh\"",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/pipeline-chainguard.sh\"",
        "timeoutSec": 5
      }
    ]
  }
}
