{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-session-start.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-before-agent.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-pre-tool.sh\"",
            "name": "dev-guards",
            "timeout": 15000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-post-tool.sh\"",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash \"${extensionPath}/hooks/scripts/gemini-pipeline-chainguard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
