{
  "name": "infra",
  "description": "Infrastructure development plugin: Ansible roles and collections with Molecule testing (Podman driver), IaC conventions, and Make-centric workflow.",
  "version": "0.1.16",
  "author": {
    "name": "Emmanuel Roux"
  },
  "license": "MIT",
  "keywords": [
    "ansible",
    "molecule",
    "infrastructure",
    "iac",
    "podman",
    "makefile"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/pre-tool.sh\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}