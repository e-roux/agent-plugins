{
  "name": "vulcan",
  "description": "Expert agent for building GitHub Copilot CLI plugins, extensions, and standalone SDK applications (TypeScript)",
  "version": "0.21.6",
  "author": {
    "name": "e-roux"
  },
  "license": "MIT",
  "keywords": [
    "copilot-cli",
    "copilot-sdk",
    "plugin",
    "extension",
    "typescript",
    "agent"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/inject-memory.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/version-check.sh\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}