{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/dev/hooks/scripts/gemini-session-start.sh\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/infra/hooks/scripts/gemini-session-start.sh\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/vulcan/scripts/inject-memory.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/dev/hooks/scripts/gemini-before-agent.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/dev/hooks/scripts/gemini-pre-tool.sh\"",
            "name": "dev-guards",
            "timeout": 15000
          }
        ]
