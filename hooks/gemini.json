      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/infra/hooks/scripts/gemini-pre-tool.sh\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/dev/hooks/scripts/gemini-post-tool.sh\"",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${extensionPath}/plugins/dev/hooks/scripts/gemini-pipeline-chainguard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}