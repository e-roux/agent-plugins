#!/usr/bin/env bash
set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_ref" =~ ^refs/tags/(.*)$ ]]; then
    tag="${BASH_REMATCH[1]}"
    
    if [[ "$tag" =~ ^dev/ || "$tag" =~ ^v[0-9] ]]; then
      binary_path="plugins/dev/mcp-git-ops/mcp-git-ops"
      if [ ! -f "$binary_path" ]; then
        printf "\n\033[1;31m[REJECTED]\033[0m Pushing tag '%s' is blocked because the compiled MCP server binary is missing.\n" "$tag"
        printf "Please compile the binary first (e.g. run 'make build' inside plugins/dev/mcp-git-ops) before pushing this tag.\n\n"
        exit 1
      fi
    fi
  fi
done

exit 0
